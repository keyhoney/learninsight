# 사이트 URL (canonical, sitemap, robots.txt에 사용)
NEXT_PUBLIC_SITE_URL=https://example.com

# 이미지 호스팅 베이스 URL (MDX 상대 경로와 결합, 예: Cloudflare Pages)
